---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RegexTester from '../../components/tools/RegexTester';

const faq = [
  { question: "How do I test a regular expression online?", answer: "Type your regex pattern in the pattern field and paste your test string below. Matches are highlighted in real-time as you type. Toggle flags like global (g), case-insensitive (i), multiline (m), dotAll (s), and unicode (u) to fine-tune matching behavior." },
  { question: "What regex flags are supported?", answer: "This regex tester supports all standard JavaScript regex flags: g (global — find all matches), i (case-insensitive), m (multiline — ^ and $ match line boundaries), s (dotAll — . matches newlines), and u (unicode — full Unicode support)." },
  { question: "Can I see capture groups in the results?", answer: "Yes. When your regex contains capture groups using parentheses, the tool displays each numbered group ($1, $2, etc.) and named groups (?<name>...) separately so you can verify your pattern extracts the right data." },
  { question: "How does search and replace work?", answer: "Switch to 'Replace' mode using the tab at the top. Enter your replacement string — you can use $1, $2 for numbered groups or $<name> for named groups. The result updates in real-time as you type." },
  { question: "Can I share my regex with someone?", answer: "Yes! Click the 'Share' button to generate a shareable URL that encodes your pattern, flags, test string, and replacement string. Anyone who opens the link sees the exact same regex test setup." },
  { question: "Is my test data sent to a server?", answer: "No. All regex matching runs entirely in your browser using JavaScript's built-in RegExp engine. Your patterns and test strings never leave your device." },
  { question: "How is this different from regex101?", answer: "This regex tester is designed to be lighter and faster. It loads instantly as a static page with zero server dependencies. Every feature — matching, replacing, capture groups, and sharing — works 100% client-side." },
];
---

<ToolLayout title="Regex Tester & Debugger" description="Test, debug, and share regular expressions with real-time matching, capture groups, search & replace, and a built-in cheat sheet. Free, fast, 100% browser-based." slug="regex-tester" toolName="Regex Tester" faq={faq}>
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Tools</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    <span class="text-gray-900 dark:text-gray-100 font-medium">Regex Tester</span>
  </nav>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">Regex Tester & Debugger</h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">Test and debug regular expressions with real-time match highlighting, capture group inspection, search &amp; replace, and a built-in cheat sheet. Everything runs in your browser &mdash; no data is sent to any server.</p>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <RegexTester client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        ()
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Capture Groups</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">See numbered and named capture groups for every match. Verify your regex extracts exactly the data you need.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        s/
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Search & Replace</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Switch to replace mode and preview substitutions in real-time. Supports group references like $1 and $&lt;name&gt;.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Shareable URLs</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Share your regex test with one click. Pattern, flags, test string, and replacement are encoded right in the URL.</p>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-5 group">
          <summary class="font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none flex items-center justify-between">
            {item.question}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>
