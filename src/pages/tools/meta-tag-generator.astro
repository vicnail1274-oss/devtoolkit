---
import ToolLayout from '../../layouts/ToolLayout.astro';
import MetaTagGenerator from '../../components/tools/MetaTagGenerator';

const faq = [
  { question: "What are meta tags?", answer: "Meta tags are HTML elements that provide metadata about a web page. They help search engines understand your content and control how your page appears in search results and social media shares." },
  { question: "Which meta tags are most important for SEO?", answer: "The most important meta tags are: title tag (appears in search results), meta description (shown below title in results), canonical URL (prevents duplicate content), robots meta (controls indexing), and Open Graph tags (social sharing appearance)." },
  { question: "How long should my meta title and description be?", answer: "Keep your title under 60 characters and description under 160 characters. Google may truncate longer titles and descriptions in search results. Our tool shows character counts to help you stay within limits." },
  { question: "What size should my OG image be?", answer: "The recommended Open Graph image size is 1200x630 pixels (1.91:1 aspect ratio). This works well across Facebook, Twitter, LinkedIn, and other social platforms." },
];
---

<ToolLayout
  title="Meta Tag Generator"
  description="Generate SEO meta tags with live Google, Twitter, and Facebook previews. Copy-ready HTML for your website."
  slug="meta-tag-generator"
  toolName="Meta Tag Generator"
  faq={faq}
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      Meta Tag Generator
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Generate perfect SEO meta tags with live previews for Google, Twitter/X, and Facebook. See exactly how your page will appear in search results and social shares.
    </p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <MetaTagGenerator client:load />
  </div>

  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Live Google Preview</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">See exactly how your page will look in Google search results as you type.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">SEO Score Check</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Real-time SEO checklist validates title length, description, OG image, and more.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Copy-Ready Code</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">One-click copy of complete HTML meta tags ready to paste into your &lt;head&gt;.</p>
    </div>
  </div>

  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-5 group">
          <summary class="font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none flex items-center justify-between">
            {item.question}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>
