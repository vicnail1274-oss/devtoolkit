---
import ToolLayout from '../../layouts/ToolLayout.astro';
import LoremIpsumGenerator from '../../components/tools/LoremIpsumGenerator';

const faq = [
  { question: "What is Lorem Ipsum?", answer: "Lorem Ipsum is placeholder text used in design and typesetting since the 1500s. It approximates the look of natural language without being distracting, letting designers focus on visual layout rather than content." },
  { question: "Can I generate specific amounts of text?", answer: "Yes. Choose to generate by paragraphs, sentences, or words, and specify exactly how many you need. The tool produces natural-looking Latin text in your chosen quantity." },
  { question: "Is Lorem Ipsum real Latin?", answer: "It is derived from a work by Cicero written in 45 BC, but the text has been altered and scrambled over centuries. It is not meaningful Latin — it exists purely as placeholder text." },
  { question: "When should I use placeholder text?", answer: "Use Lorem Ipsum during early design phases, wireframing, and prototyping when final content is not yet available. It helps stakeholders evaluate layouts without being distracted by draft content." },
];
---

<ToolLayout
  title="Lorem Ipsum Generator"
  description="Generate lorem ipsum placeholder text with configurable paragraphs, sentences, or words"
  slug="lorem-ipsum"
  toolName="Lorem Ipsum Generator"
  faq={faq}
>
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      Lorem Ipsum Generator
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Generate placeholder text by paragraphs, sentences, or words. Everything runs in your browser &mdash; no data is sent to any server.
    </p>
  </div>

  <!-- Tool Component -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <LoremIpsumGenerator client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Configurable Output</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Choose paragraphs, sentences, or words. Set any count from 1 to 100.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">One-Click Copy</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Copy generated text to clipboard instantly. Word and character counts included.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">100% Private</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Your data never leaves your browser. No tracking, no cookies, no server-side processing.
      </p>
    </div>
  </div>
</ToolLayout>
