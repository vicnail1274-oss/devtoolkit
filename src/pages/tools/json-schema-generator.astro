---
import ToolLayout from '../../layouts/ToolLayout.astro';
import JsonSchemaGenerator from '../../components/tools/JsonSchemaGenerator';

const faq = [
  { question: "What is JSON Schema?", answer: "JSON Schema is a vocabulary for annotating and validating JSON documents. It describes the structure, types, and constraints of your data, making it useful for API documentation, form validation, and data interchange." },
  { question: "How does the generator infer types?", answer: "The tool analyzes each value in your JSON: strings become 'string', whole numbers become 'integer', decimals become 'number', true/false become 'boolean', arrays and objects are detected with their nested structures preserved." },
  { question: "Does it handle nested objects?", answer: "Yes. The generator recursively processes all nested objects and arrays, creating a complete schema that mirrors your entire data structure including deeply nested properties." },
  { question: "Is my data safe?", answer: "Yes. Everything runs entirely in your browser. No data is ever sent to a server. Your JSON never leaves your device." },
  { question: "Which JSON Schema draft should I use?", answer: "Draft-07 is the most widely supported version across validators and tools. Draft 2020-12 is the latest standard with additional features like dynamic references. Choose based on your toolchain's support." },
];
---

<ToolLayout
  title="JSON Schema Generator"
  description="Generate JSON Schema from any JSON data instantly. Free online tool with type inference and nested object support."
  slug="json-schema-generator"
  toolName="JSON Schema Generator"
  faq={faq}
>
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Tools</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-900 dark:text-gray-100 font-medium">JSON Schema Generator</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      JSON Schema Generator
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Paste any JSON and instantly generate a valid JSON Schema with type inference, required fields, and nested object support.
    </p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <JsonSchemaGenerator client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Smart Type Inference</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Automatically detects string, integer, number, boolean, array, and null types from your JSON values.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Deep Nesting Support</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Handles deeply nested objects and arrays of objects, producing complete schemas for complex data structures.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">100% Private</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        All processing happens in your browser. No data is sent to any server, ever.
      </p>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-5 group">
          <summary class="font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none flex items-center justify-between">
            {item.question}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>
