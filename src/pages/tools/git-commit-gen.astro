---
import ToolLayout from '../../layouts/ToolLayout.astro';
import GitCommitGen from '../../components/tools/GitCommitGen';

const faq = [
  { question: "What is Conventional Commits?", answer: "Conventional Commits is a commit message specification that uses a structured format: type(scope): description. Common types include feat (new feature), fix (bug fix), refactor, docs, test, and chore. It makes commit history readable and enables automated changelogs." },
  { question: "How does the commit generator work?", answer: "Describe your change in plain English. The tool analyzes keywords to infer the most appropriate commit types, extracts a scope when possible, and formats 5 suggestions following the Conventional Commits spec." },
  { question: "Does this use AI or an API?", answer: "No. The generator is entirely rule-based and runs 100% in your browser. No data is sent anywhere and no API key is needed." },
  { question: "Can I use this for any language or framework?", answer: "Yes. The generator is language-agnostic. It works for any codebase — JavaScript, Python, Go, Rust, or anything else — because it focuses on the nature of the change, not the technology." },
  { question: "What is the 50/72 rule for commit messages?", answer: "The subject line (first line) of a commit message should be 50 characters or fewer, and must not exceed 72. This tool enforces the 72-character hard limit automatically." },
  { question: "What is a commit scope?", answer: "The scope is an optional part of the commit header that describes which part of the codebase was changed, e.g. feat(auth): add OAuth login. The tool auto-detects scopes from phrases like 'in the login form' or 'payment service'." },
];
---

<ToolLayout
  title="Git Commit Message Generator"
  description="Generate 5 Conventional Commit message suggestions from a plain-English description. Client-side, no API key needed."
  slug="git-commit-gen"
  toolName="Git Commit Generator"
  faq={faq}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Tools</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    <span class="text-gray-900 dark:text-gray-100 font-medium">Git Commit Generator</span>
  </nav>

  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      Git Commit Message Generator
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Describe your change in plain English and get 5 <a href="https://www.conventionalcommits.org/" target="_blank" rel="noopener" class="text-primary-600 dark:text-primary-400 hover:underline">Conventional Commit</a> suggestions instantly. No API key, no server.
    </p>
  </div>

  <!-- Tool Component -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <GitCommitGen client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        🔀
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">5 Type Suggestions</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Get commit messages for the 5 most likely types (feat, fix, refactor, etc.) based on what you describe. Pick the one that fits best.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        ()
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Auto-Detected Scope</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">The tool extracts a scope from your description when possible — e.g. "in the auth module" becomes <code class="font-mono">feat(auth):</code>.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">72-Char Enforced</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">All generated messages respect the 72-character subject line limit. Longer descriptions are truncated automatically with an ellipsis.</p>
    </div>
  </div>
</ToolLayout>
