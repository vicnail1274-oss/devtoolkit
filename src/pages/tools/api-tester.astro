---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ApiTester from '../../components/tools/ApiTester';

const faq = [
  { question: "What is the API Tester?", answer: "It's a lightweight, browser-based HTTP client similar to Postman. You can send GET, POST, PUT, DELETE, and PATCH requests directly from your browser without installing any software." },
  { question: "Why do some requests fail with CORS errors?", answer: "Browsers enforce Cross-Origin Resource Sharing (CORS) policies that block requests to servers that don't allow cross-origin access. This is a browser security feature. Try testing APIs that support CORS, or use this tool to test your own APIs during development." },
  { question: "Is my data safe?", answer: "Requests are sent directly from your browser to the target API. No data passes through our servers. Your URLs, headers, and request bodies are never stored or logged." },
  { question: "Can I send JSON request bodies?", answer: "Yes. Switch to the Body tab, enter your JSON payload, and make sure the Content-Type header is set to application/json. The tool works with POST, PUT, and PATCH methods." },
  { question: "Does it support authentication?", answer: "Yes. Add your authentication tokens via the Headers tab. Common patterns include 'Authorization: Bearer your-token' or 'X-API-Key: your-key'." },
];
---

<ToolLayout
  title="API Tester - Online HTTP Client"
  description="Test REST APIs directly from your browser. Send GET, POST, PUT, DELETE requests with custom headers and body. Free Postman alternative."
  slug="api-tester"
  toolName="API Tester"
  faq={faq}
>
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Tools</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-900 dark:text-gray-100 font-medium">API Tester</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      API Tester
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      A lightweight Postman alternative in your browser. Send HTTP requests, inspect responses, and debug APIs &mdash; no signup or install required.
    </p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <ApiTester client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">All HTTP Methods</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Support for GET, POST, PUT, DELETE, and PATCH with custom headers and request body.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Response Insights</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        See status codes, response time, size, headers, and auto-formatted JSON body at a glance.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">No Server Middleman</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Requests go directly from your browser to the API. No proxy, no logging, no data collection.
      </p>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-5 group">
          <summary class="font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none flex items-center justify-between">
            {item.question}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>
