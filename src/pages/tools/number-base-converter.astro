---
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberBaseConverter from '../../components/tools/NumberBaseConverter';

const faq = [
  { question: "What number bases are supported?", answer: "The tool converts between binary (base 2), octal (base 8), decimal (base 10), and hexadecimal (base 16). Enter a number in any base and instantly see it in all other bases." },
  { question: "Why do programmers need base conversion?", answer: "Binary is how computers store data. Hexadecimal is used for memory addresses, color codes, and byte representations. Octal is used in Unix file permissions. Understanding base conversion is essential for low-level programming and debugging." },
  { question: "How do I read hexadecimal numbers?", answer: "Hexadecimal uses digits 0-9 and letters A-F, where A=10, B=11, C=12, D=13, E=14, F=15. Each hex digit represents 4 binary bits. For example, FF in hex equals 255 in decimal and 11111111 in binary." },
  { question: "Is this tool free?", answer: "Yes, completely free with no signup required. All conversions run instantly in your browser." },
];
---

<ToolLayout
  title="Number Base Converter"
  description="Convert numbers between binary, octal, decimal, and hexadecimal. Free online base converter."
  slug="number-base-converter"
  toolName="Number Base Converter"
  faq={faq}
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      Number Base Converter
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Convert numbers between binary (base 2), octal (base 8), decimal (base 10), and hexadecimal (base 16). Type in any field and all others update instantly.
    </p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <NumberBaseConverter client:load />
  </div>

  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Real-time Conversion</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Type in any base field and all other bases update instantly. No button clicking needed.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">BigInt Support</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Handles arbitrarily large numbers using BigInt. No precision loss even with very large values.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Bit Analysis</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        See bit count, byte count, hex digits, and whether the number is a power of 2.
      </p>
    </div>
  </div>
</ToolLayout>
