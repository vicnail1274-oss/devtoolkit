---
import ToolLayout from '../../layouts/ToolLayout.astro';
import JsonDiffViewer from '../../components/tools/JsonDiffViewer';

const faq = [
  { question: "What is a JSON diff viewer?", answer: "A JSON diff viewer compares two JSON objects and highlights the differences — added keys, removed keys, and changed values — so you can quickly understand what changed between two versions." },
  { question: "How does the JSON diff work?", answer: "Paste your original JSON on the left and the modified JSON on the right, then click Compare JSON. The tool recursively walks through both objects and shows additions (green), removals (red), and value changes (yellow)." },
  { question: "Does it support nested objects and arrays?", answer: "Yes. The diff is fully recursive. Nested objects show a grouped diff tree, and array elements are compared by index." },
  { question: "Is my JSON data sent to a server?", answer: "No. All comparison runs entirely in your browser using JavaScript. Your JSON never leaves your device." },
  { question: "What does the diff report show?", answer: "The report shows a count of added, removed, and changed fields. You can also copy the full diff as a plain-text report for sharing in tickets or code reviews." },
  { question: "How is this different from a text diff?", answer: "A text diff compares raw strings line by line. A JSON diff understands the structure — it compares keys and values semantically, regardless of key ordering or whitespace." },
];
---

<ToolLayout
  title="JSON Diff Viewer"
  description="Compare two JSON objects and highlight added, removed, and changed keys instantly. Recursive, client-side, free."
  slug="json-diff"
  toolName="JSON Diff Viewer"
  faq={faq}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Tools</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    <span class="text-gray-900 dark:text-gray-100 font-medium">JSON Diff Viewer</span>
  </nav>

  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      JSON Diff Viewer
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Compare two JSON objects and see exactly what changed. Recursive diff with added, removed, and changed highlights &mdash; all in your browser.
    </p>
  </div>

  <!-- Tool Component -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <JsonDiffViewer client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        ±
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Semantic Diff</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Compares JSON structure, not raw text — key ordering doesn't matter. See exactly which keys were added, removed, or changed.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4 text-lg font-bold font-mono">
        { }
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Recursive Nesting</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Deeply nested objects and arrays are walked recursively. Changes inside nested structures are shown inline in context.</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Copy Report</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Export a plain-text diff report with +/−/~ prefixes. Paste directly into pull request descriptions, tickets, or Slack.</p>
    </div>
  </div>
</ToolLayout>
