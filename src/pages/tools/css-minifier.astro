---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CssMinifier from '../../components/tools/CssMinifier';

const faq = [
  { question: "What does CSS minification do?", answer: "CSS minification removes unnecessary characters like whitespace, comments, and line breaks without changing functionality. This reduces file size, leading to faster page loads and better performance scores." },
  { question: "How much smaller will my CSS be after minification?", answer: "Typical savings range from 20-40% depending on how much whitespace and comments your original CSS contains. The tool shows you the exact before/after sizes and percentage saved." },
  { question: "Will minification break my CSS?", answer: "No. Minification only removes characters that are not needed for the browser to interpret the CSS correctly. Your styles will work exactly the same way after minification." },
  { question: "Is my CSS sent to a server?", answer: "No. All minification is performed in your browser using JavaScript. Your CSS code never leaves your device." },
];
---

<ToolLayout
  title="CSS Minifier"
  description="Minify CSS code online for free with size savings report"
  slug="css-minifier"
  toolName="CSS Minifier"
  faq={faq}
>
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      CSS Minifier
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Paste your CSS and get minified output with size savings. Everything runs in your browser &mdash; no data is sent to any server.
    </p>
  </div>

  <!-- Tool Component -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <CssMinifier client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Instant Minification</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Remove comments, whitespace, and unnecessary characters from CSS in milliseconds.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Size Report</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        See original vs minified size and percentage saved at a glance.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">100% Private</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Your data never leaves your browser. No tracking, no cookies, no server-side processing.
      </p>
    </div>
  </div>
</ToolLayout>
