---
import ToolLayout from '../../layouts/ToolLayout.astro';
import IpLookup from '../../components/tools/IpLookup';

const faq = [
  { question: "How do you detect my IP address?", answer: "We use a third-party geolocation API (ipinfo.io) to look up your public IP address and associated metadata. The request goes directly from your browser to the API — we do not proxy or store any data." },
  { question: "What information can I see about an IP address?", answer: "You can see the city, region, country, latitude/longitude coordinates, postal code, timezone, and ISP/organization associated with an IP address." },
  { question: "Is this tool accurate?", answer: "IP geolocation is generally accurate to the city level for most commercial ISPs. VPN or proxy users may see the location of the VPN server rather than their physical location." },
  { question: "Does this tool support IPv6?", answer: "Yes. You can look up both IPv4 and IPv6 addresses. Your own detected IP will show whichever version your browser uses to connect." },
];
---

<ToolLayout
  title="IP Address Lookup"
  description="Detect your public IP address and look up geolocation info for any IP. Free online tool."
  slug="ip-lookup"
  toolName="IP Address Lookup"
  faq={faq}
>
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
      IP Address Lookup
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">
      Instantly detect your public IP address and look up geolocation data for any IP. City, region, country, timezone, and ISP info at your fingertips.
    </p>
  </div>

  <!-- Tool Component -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
    <IpLookup client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Auto-Detect Your IP</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        See your public IP address and geolocation info instantly when you open the page.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Geolocation Data</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        City, region, country, coordinates, timezone, and ISP for any IP address.
      </p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 p-6">
      <div class="w-10 h-10 bg-primary-50 dark:bg-primary-950 rounded-lg flex items-center justify-center text-primary-600 dark:text-primary-400 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">IPv4 & IPv6 Support</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Look up both IPv4 and IPv6 addresses. Enter any public IP to get detailed info.
      </p>
    </div>
  </div>
</ToolLayout>
