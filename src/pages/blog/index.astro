    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
      Developer guides, tutorials, and comparisons to help you work smarter.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-6">
    {posts.map((post) => (
      <a
        href={`/blog/${post.slug}`}
        class="group block bg-white dark:bg-gray-900 rounded-xl shadow-sm hover:shadow-lg border border-gray-200 dark:border-gray-800 p-6 transition-all duration-200 hover:-translate-y-0.5"
      >
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-block text-xs font-medium px-2.5 py-0.5 rounded-full bg-primary-50 dark:bg-primary-950 text-primary-600 dark:text-primary-400">
            {post.category}
          </span>
          <span class="text-sm text-gray-400 dark:text-gray-500">{post.readTime}</span>
        </div>
        <h2 class="text-xl font-semibold mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-200">
          {post.title}
        </h2>
        <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
          {post.description}
        </p>
        <div class="mt-4 text-sm text-gray-400 dark:text-gray-500">
          <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        </div>
      </a>
    ))}
  </div>
</ToolLayout>
