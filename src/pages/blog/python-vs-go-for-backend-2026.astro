  '        # Non-blocking HTTP call to an upstream service',
  '        resp = await client.get(f"https://api.example.com/users/{user_id}")',
  '        user_data = resp.json()',
  '',
  '    # Non-blocking database query (using async driver)',
  '    profile = await db.fetch_one(',
  '        "SELECT * FROM profiles WHERE user_id = :uid",',
  '        values={"uid": user_id},',
  '    )',
