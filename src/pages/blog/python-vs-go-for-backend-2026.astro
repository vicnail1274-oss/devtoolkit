const codeBlock2 = [
  '// Go — net/http handler with concurrent upstream call',
  'package main',
  '',
  'import (',
  '    "encoding/json"',
  '    "fmt"',
  '    "net/http"',
  '    "io"',
  ')',
  '',
  'func getUserHandler(w http.ResponseWriter, r *http.Request) {',
  '    userID := r.PathValue("user_id")',
  '',
  '    // Launch upstream API call in a goroutine',
  '    type result struct {',
  '        data []byte',
  '        err  error',
  '    }',
  '    ch := make(chan result, 1)',
  '',
  '    go func() {',
  '        resp, err := http.Get(fmt.Sprintf("https://api.example.com/users/%s", userID))',
  '        if err != nil {',
  '            ch &lt;- result{nil, err}',
  '            return',
  '        }',
  '        defer resp.Body.Close()',
  '        body, err := io.ReadAll(resp.Body)',
  '        ch &lt;- result{body, err}',
  '    }()',
  '',
  '    // Meanwhile, query the database (synchronous-looking but non-blocking)',
  '    profile, err := db.QueryRow("SELECT * FROM profiles WHERE user_id = $1", userID)',
  '    if err != nil {',
  '        http.Error(w, "db error", 500)',
  '        return',
  '    }',
  '',
  '    // Wait for the upstream call',
  '    apiResult := &lt;-ch',
  '    if apiResult.err != nil {',
  '        http.Error(w, "upstream error", 502)',
  '        return',
  '    }',
  '',
  '    json.NewEncoder(w).Encode(map[string]any{',
  '        "user":    json.RawMessage(apiResult.data),',
  '        "profile": profile,',
  '    })',
  '}',
  '',
  'func main() {',
  '    mux := http.NewServeMux()',
  '    mux.HandleFunc("GET /users/{user_id}", getUserHandler)',
  '    http.ListenAndServe(":8080", mux)',
  '}'
].join('\n');

