  '  }',
  '',
  '  select&lt;K extends keyof T&gt;(key: K): T[K] {',
  '    return this.state[key];',
  '  }',
  '',
  '  subscribe(listener: Listener&lt;T&gt;): () =&gt; void {',
  '    this.listeners.add(listener);',
  '    return () =&gt; this.listeners.delete(listener);',
  '  }',
  '}',
  '',
  '// Usage',
  'interface AppState {',
  '  user: User | null;',
  '  theme: "light" | "dark";',
  '  notifications: string[];',
  '}',
  '',
  'const store = new Store&lt;AppState&gt;({',
  '  user: null,',
  '  theme: "light",',
  '  notifications: [],',
  '});',
  '',
  'store.setState({ theme: "dark" });          // OK',
  'store.setState((prev) =&gt; ({',
  '  notifications: [...prev.notifications, "New message"],',
  '}));',
  '',
  'const theme = store.select("theme"); // type: "light" | "dark"',
  '// store.setState({ theme: "blue" }); // Error: "blue" is not assignable'
].join('\n');

const codeBlock21 = [
  'type ValidationRule&lt;T&gt; = {',
  '  validate: (value: T) =&gt; boolean;',
  '  message: string;',
  '};',
  '',
  'type FormValidator&lt;T&gt; = {',
  '  [K in keyof T]?: ValidationRule&lt;T[K]&gt;[];',
  '};',
  '',
  'type ValidationErrors&lt;T&gt; = {',
  '  [K in keyof T]?: string[];',
  '};',
  '',
  'function validateForm&lt;T extends Record&lt;string, unknown&gt;&gt;(',
  '  data: T,',
  '  validators: FormValidator&lt;T&gt;',
  '): { valid: boolean; errors: ValidationErrors&lt;T&gt; } {',
  '  const errors: ValidationErrors&lt;T&gt; = {};',
  '  let valid = true;',
  '',
  '  for (const key in validators) {',
  '    const rules = validators[key];',
  '    if (!rules) continue;',
  '',
  '    const fieldErrors: string[] = [];',
  '    for (const rule of rules) {',
  '      if (!rule.validate(data[key] as any)) {',
  '        fieldErrors.push(rule.message);',
  '        valid = false;',
  '      }',
  '    }',
  '',
  '    if (fieldErrors.length &gt; 0) {',
  '      errors[key] = fieldErrors;',
  '    }',
  '  }',
  '',
  '  return { valid, errors };',
  '}',
  '',
  '// Usage',
  'interface SignupForm {',
  '  username: string;',
  '  email: string;',
  '  age: number;',
  '}',
  '',
  'const signupValidators: FormValidator&lt;SignupForm&gt; = {',
  '  username: [',
  '    { validate: (v) =&gt; v.length &gt;= 3, message: "Min 3 characters" },',
  '    { validate: (v) =&gt; /^[a-zA-Z0-9_]+$/.test(v), message: "Alphanumeric only" },',
  '  ],',
  '  email: [',
  '    { validate: (v) =&gt; v.includes("@"), message: "Must contain @" },',
  '  ],',
  '  age: [',
  '    { validate: (v) =&gt; v &gt;= 18, message: "Must be 18 or older" },',
  '  ],',
  '};',
  '',
  'const result = validateForm(',
  '  { username: "ab", email: "invalid", age: 16 },',
  '  signupValidators',
  ');',
  '// result.errors.username = ["Min 3 characters"]',
  '// result.errors.email = ["Must contain @"]',
  '// result.errors.age = ["Must be 18 or older"]'
].join('\n');

const codeBlock22 = [
  '// Hard to read',
  'function process&lt;T, U, V&gt;(input: T, transform: (x: T) =&gt; U, format: (x: U) =&gt; V): V { ... }',
  '',
  '// Easier to understand',
  'function process&lt;TInput, TIntermediate, TOutput&gt;(',
  '  input: TInput,',
  '  transform: (x: TInput) =&gt; TIntermediate,',
  '  format: (x: TIntermediate) =&gt; TOutput',
  '): TOutput { ... }'
].join('\n');

const codeBlock23 = [
  '// Too broad — T could be anything',
  'function processItems&lt;T&gt;(items: T[]): void {',
  '  items.forEach((item) =&gt; console.log(item.toString()));',
  '}',
  '',
  '// Just right — only requires what we actually use',
  'function processItems&lt;T extends { toString(): string }&gt;(items: T[]): void {',
  '  items.forEach((item) =&gt; console.log(item.toString()));',
  '}'
].join('\n');

const codeBlock24 = [
  '// Unnecessary generic — T appears only once',
  'function greet&lt;T extends string&gt;(name: T): void {',
  '  console.log(\\`Hello, \\${name}\\`);',
  '}',
  '',
  '// Better — just use the concrete type',
  'function greet(name: string): void {',
  '  console.log(\\`Hello, \\${name}\\`);',
  '}'
].join('\n');

const codeBlock25 = [
  '// Prefer interface for generic object shapes',
  'interface Result&lt;T&gt; {',
  '  data: T;',
  '  error: string | null;',
  '}',
  '',
  '// Use type alias for unions, intersections, and computed types',
  'type Either&lt;L, R&gt; = { tag: "left"; value: L } | { tag: "right"; value: R };'
].join('\n');

const codeBlock26 = [
  '// This does NOT work — types are erased at runtime',
  'function createInstance&lt;T&gt;(): T {',
  "  return new T(); // Error: 'T' only refers to a type, but is used as a value",
  '}',
  '',
  '// Solution: pass the constructor as a parameter',
  'function createInstance&lt;T&gt;(ctor: new () =&gt; T): T {',
  '  return new ctor();',
  '}',
  '',
  'class MyClass {',
  '  value = 42;',
  '}',
  '',
  'const instance = createInstance(MyClass); // type is MyClass'
].join('\n');

const codeBlock27 = [
  '// Too complex',
  'type Query&lt;T, K, F, S, P&gt; = ...',
  '',
  '// Better: compose smaller types',
  'type FilterConfig&lt;T&gt; = { field: keyof T; value: T[keyof T] };',
  'type SortConfig&lt;T&gt; = { field: keyof T; direction: "asc" | "desc" };',
  'type QueryConfig&lt;T&gt; = {',
  '  filters: FilterConfig&lt;T&gt;[];',
  '  sort: SortConfig&lt;T&gt;;',
  '  page: number;',
  '  limit: number;',
  '};'
].join('\n');

const codeBlock28 = [
  '// This does not work as expected',
  'function isString&lt;T&gt;(value: T): value is T &amp; string {',
  '  return typeof value === "string";',
  '}',
  '',
  '// TypeScript cannot narrow generic types easily in some contexts.',
  '// When in doubt, use explicit type guards outside of generic functions.'
].join('\n');

const codeBlock29 = [
  'interface ListProps&lt;T&gt; {',
  '  items: T[];',
  '  renderItem: (item: T, index: number) =&gt; React.ReactNode;',
  '  keyExtractor: (item: T) =&gt; string;',
  '  emptyMessage?: string;',
  '}',
  '',
  'function List&lt;T&gt;({ items, renderItem, keyExtractor, emptyMessage }: ListProps&lt;T&gt;) {',
  '  if (items.length === 0) {',
  '    return &lt;p&gt;{emptyMessage ?? "No items"}&lt;/p&gt;;',
  '  }',
  '',
  '  return (',
  '    &lt;ul&gt;',
  '      {items.map((item, i) =&gt; (',
  '        &lt;li key={keyExtractor(item)}&gt;{renderItem(item, i)}&lt;/li&gt;',
  '      ))}',
  '    &lt;/ul&gt;',
  '  );',
  '}',
  '',
  '// Usage: T is inferred as User',
  '&lt;List',
  '  items={users}',
  '  renderItem={(user) =&gt; &lt;span&gt;{user.name}&lt;/span&gt;}',
  '  keyExtractor={(user) =&gt; user.id}',
  '/&gt;'
].join('\n');
