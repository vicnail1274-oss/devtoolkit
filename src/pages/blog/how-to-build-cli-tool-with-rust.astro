---
import BlogLayout from '../../layouts/BlogLayout.astro';

const codeBlock = [
  '[package]',
  'name = "fxr"',
  'version = "0.1.0"',
  'edition = "2021"',
  'description = "A fast file search and transform utility"',
  'license = "MIT"',
  'repository = "https://github.com/yourusername/fxr"',
  'keywords = ["cli", "search", "transform", "files"]',
  'categories = ["command-line-utilities"]',
  '',
  '[dependencies]',
  'clap = { version = "4.5", features = ["derive"] }',
  'serde = { version = "1.0", features = ["derive"] }',
  'serde_json = "1.0"',
  'serde_yaml = "0.9"',
  'colored = "2.1"',
  'anyhow = "1.0"',
  'thiserror = "1.0"',
  'indicatif = "0.17"',
  'walkdir = "2.5"',
  'regex = "1.10"',
  '',
  '[profile.release]',
  'opt-level = 3',
  'lto = true',
  'codegen-units = 1',
  'strip = true'
].join('\n');

const codeBlock2 = [
  'use clap::{Parser, Subcommand};',
  '',
  '/// fxr — A fast file search and transform utility',
  '#[derive(Parser, Debug)]',
  '#[command(name = "fxr")]',
  '#[command(version, about, long_about = None)]',
  'struct Cli {',
  '    /// Enable verbose output',
  '    #[arg(short, long, global = true)]',
  '    verbose: bool,',
  '',
  '    /// Output format (text, json, yaml)',
  '    #[arg(short, long, default_value = "text", global = true)]',
  '    format: OutputFormat,',
  '',
  '    #[command(subcommand)]',
  '    command: Commands,',
  '}',
  '',
  '#[derive(Debug, Clone, clap::ValueEnum)]',
  'enum OutputFormat {',
  '    Text,',
  '    Json,',
  '    Yaml,',
  '}',
  '',
  '#[derive(Subcommand, Debug)]',
  'enum Commands {',
  '    /// Search for files matching a pattern',
  '    Find {',
  '        /// The search pattern (supports regex)',
  '        pattern: String,',
  '',
  '        /// Directory to search in',
  '        #[arg(short, long, default_value = ".")]',
  '        dir: String,',
  '',
  '        /// Maximum search depth',
  "        #[arg(short = 'D', long)]",
  '        max_depth: Option&lt;usize&gt;,',
  '',
  '        /// Only show files with this extension',
  '        #[arg(short, long)]',
  '        ext: Option&lt;String&gt;,',
  '    },',
  '',
  '    /// Search file contents for a pattern',
  '    Grep {',
  '        /// The regex pattern to search for',
  '        pattern: String,',
  '',
  '        /// Directory to search in',
  '        #[arg(short, long, default_value = ".")]',
  '        dir: String,',
  '',
  '        /// File extensions to include (comma-separated)',
  '        #[arg(short, long)]',
  '        include: Option&lt;String&gt;,',
  '',
  '        /// Show N lines of context around matches',
  '        #[arg(short = \'C\', long, default_value = "0")]',
  '        context: usize,',
  '    },',
  '',
  '    /// Convert files between formats (JSON &lt;-&gt; YAML)',
  '    Convert {',
  '        /// Input file path',
  '        input: String,',
  '',
  '        /// Output file path (inferred from extension if omitted)',
  '        #[arg(short, long)]',
  '        output: Option&lt;String&gt;,',
  '',
  '        /// Pretty-print the output',
  '        #[arg(short, long)]',
  '        pretty: bool,',
  '    },',
  '',
  '    /// Show file statistics',
  '    Stats {',
  '        /// Directory to analyze',
  '        #[arg(default_value = ".")]',
  '        dir: String,',
  '    },',
  '}'
].join('\n');

const codeBlock3 = [
  'use anyhow::Result;',
  '',
  'fn main() -&gt; Result&lt;()&gt; {',
  '    let cli = Cli::parse();',
  '',
  '    match cli.command {',
  '        Commands::Find { pattern, dir, max_depth, ext } =&gt; {',
  '            cmd_find(&amp;pattern, &amp;dir, max_depth, ext.as_deref(), cli.verbose, &amp;cli.format)',
  '        }',
  '        Commands::Grep { pattern, dir, include, context } =&gt; {',
  '            cmd_grep(&amp;pattern, &amp;dir, include.as_deref(), context, cli.verbose, &amp;cli.format)',
  '        }',
  '        Commands::Convert { input, output, pretty } =&gt; {',
  '            cmd_convert(&amp;input, output.as_deref(), pretty, cli.verbose)',
  '        }',
  '        Commands::Stats { dir } =&gt; {',
  '            cmd_stats(&amp;dir, &amp;cli.format)',
  '        }',
  '    }',
  '}'
].join('\n');

const codeBlock4 = [
  'use std::fs;',
  'use std::path::Path;',
  'use anyhow::{Context, Result};',
  '',
  'fn read_file_contents(path: &amp;str) -&gt; Result&lt;String&gt; {',
  '    fs::read_to_string(path)',
  '        .with_context(|| format!("Failed to read file: {}", path))',
  '}',
  '',
  'fn write_file_contents(path: &amp;str, contents: &amp;str) -&gt; Result&lt;()&gt; {',
  '    // Ensure parent directory exists',
  '    if let Some(parent) = Path::new(path).parent() {',
  '        fs::create_dir_all(parent)',
  '            .with_context(|| format!("Failed to create directory: {}", parent.display()))?;',
  '    }',
  '',
  '    fs::write(path, contents)',
  '        .with_context(|| format!("Failed to write file: {}", path))',
  '}'
].join('\n');

const codeBlock5 = [
  'use walkdir::WalkDir;',
  'use regex::Regex;',
  'use colored::*;',
  '',
  'fn cmd_find(',
  '    pattern: &amp;str,',
  '    dir: &amp;str,',
  '    max_depth: Option&lt;usize&gt;,',
  '    ext: Option&lt;&amp;str&gt;,',
  '    verbose: bool,',
  '    format: &amp;OutputFormat,',
  ') -&gt; Result&lt;()&gt; {',
  '    let re = Regex::new(pattern)',
  '        .with_context(|| format!("Invalid regex pattern: {}", pattern))?;',
  '',
  '    let mut walker = WalkDir::new(dir);',
  '    if let Some(depth) = max_depth {',
  '        walker = walker.max_depth(depth);',
  '    }',
  '',
  '    let mut matches: Vec&lt;String&gt; = Vec::new();',
  '',
  '    for entry in walker.into_iter().filter_map(|e| e.ok()) {',
  '        let path = entry.path();',
  '        let file_name = path.file_name()',
  '            .and_then(|n| n.to_str())',
  '            .unwrap_or("");',
  '',
  '        // Filter by extension if specified',
  '        if let Some(extension) = ext {',
  '            match path.extension().and_then(|e| e.to_str()) {',
  '                Some(e) if e == extension =&gt; {}',
  '                _ =&gt; continue,',
  '            }',
  '        }',
  '',
  '        if re.is_match(file_name) {',
  '            matches.push(path.display().to_string());',
  '        }',
  '    }',
  '',
  '    match format {',
  '        OutputFormat::Json =&gt; {',
  '            println!("{}", serde_json::to_string_pretty(&amp;matches)?);',
  '        }',
  '        OutputFormat::Yaml =&gt; {',
  '            println!("{}", serde_yaml::to_string(&amp;matches)?);',
  '        }',
  '        OutputFormat::Text =&gt; {',
  '            for m in &amp;matches {',
  '                println!("{}", m.green());',
  '            }',
  '            if verbose {',
  '                eprintln!("{} files found", matches.len().to_string().cyan());',
  '            }',
  '        }',
  '    }',
  '',
  '    Ok(())',
  '}'
].join('\n');

const codeBlock6 = [
  'use serde_json::Value as JsonValue;',
  'use std::path::Path;',
  '',
  'fn cmd_convert(',
  '    input: &amp;str,',
  '    output: Option&lt;&amp;str&gt;,',
  '    pretty: bool,',
  '    verbose: bool,',
  ') -&gt; Result&lt;()&gt; {',
  '    let contents = read_file_contents(input)?;',
  '    let input_ext = Path::new(input)',
  '        .extension()',
  '        .and_then(|e| e.to_str())',
  '        .unwrap_or("");',
  '',
  '    // Parse input based on extension',
  '    let value: JsonValue = match input_ext {',
  '        "json" =&gt; serde_json::from_str(&amp;contents)',
  '            .with_context(|| "Failed to parse JSON input")?,',
  '        "yaml" | "yml" =&gt; serde_yaml::from_str(&amp;contents)',
  '            .with_context(|| "Failed to parse YAML input")?,',
  '        _ =&gt; anyhow::bail!("Unsupported input format: .{}", input_ext),',
  '    };',
  '',
  '    // Determine output format',
  '    let output_path = output.unwrap_or_else(|| {',
  '        // Leaked string for simplicity; in production, use a proper buffer',
  '        match input_ext {',
  '            "json" =&gt; "output.yaml",',
  '            _ =&gt; "output.json",',
  '        }',
  '    });',
  '',
  '    let output_ext = Path::new(output_path)',
  '        .extension()',
  '        .and_then(|e| e.to_str())',
  '        .unwrap_or("json");',
  '',
  '    let result = match output_ext {',
  '        "yaml" | "yml" =&gt; serde_yaml::to_string(&amp;value)?,',
  '        "json" if pretty =&gt; serde_json::to_string_pretty(&amp;value)?,',
  '        "json" =&gt; serde_json::to_string(&amp;value)?,',
  '        _ =&gt; anyhow::bail!("Unsupported output format: .{}", output_ext),',
  '    };',
  '',
  '    write_file_contents(output_path, &amp;result)?;',
  '',
  '    if verbose {',
  '        eprintln!(',
  '            "{} {} -> {} ({})",',
  '            "Converted:".green().bold(),',
  '            input,',
  '            output_path,',
  '            format!("{} bytes", result.len()).dimmed()',
  '        );',
  '    }',
  '',
  '    Ok(())',
  '}'
].join('\n');

const codeBlock7 = [
  'use colored::*;',
  '',
  'fn print_match(path: &amp;str, line_num: usize, line: &amp;str, pattern: &amp;Regex) {',
  '    let path_display = path.blue().bold();',
  '    let line_display = line_num.to_string().yellow();',
  '',
  '    // Highlight the matched portion',
  '    let highlighted = pattern.replace_all(line, |caps: &amp;regex::Captures| {',
  '        caps[0].red().bold().to_string()',
  '    });',
  '',
  '    println!("{}:{}: {}", path_display, line_display, highlighted);',
  '}',
  '',
  'fn print_header(text: &amp;str) {',
  '    println!("\\n{}", text.white().bold().underline());',
  '}',
  '',
  'fn print_success(text: &amp;str) {',
  '    println!("{} {}", "✓".green().bold(), text);',
  '}',
  '',
  'fn print_error(text: &amp;str) {',
  '    eprintln!("{} {}", "✗".red().bold(), text);',
  '}',
  '',
  'fn print_warning(text: &amp;str) {',
  '    eprintln!("{} {}", "⚠".yellow().bold(), text);',
  '}'
].join('\n');

const codeBlock8 = [
  'use indicatif::{ProgressBar, ProgressStyle};',
  '',
  'fn cmd_stats(dir: &amp;str, format: &amp;OutputFormat) -&gt; Result&lt;()&gt; {',
  '    // First pass: count total entries for the progress bar',
  '    let total: u64 = WalkDir::new(dir)',
  '        .into_iter()',
  '        .filter_map(|e| e.ok())',
  '        .count() as u64;',
  '',
  '    let pb = ProgressBar::new(total);',
  '    pb.set_style(',
  '        ProgressStyle::default_bar()',
  '            .template("{spinner:.green} [{elapsed_precise}] [{bar:40.cyan/blue}] {pos}/{len} ({eta})")?',
  '            .progress_chars("█▉▊▋▌▍▎▏  ")',
  '    );',
  '',
  '    let mut stats = FileStats::default();',
  '',
  '    for entry in WalkDir::new(dir).into_iter().filter_map(|e| e.ok()) {',
  '        pb.inc(1);',
  '',
  '        let path = entry.path();',
  '        if path.is_file() {',
  '            stats.total_files += 1;',
  '',
  '            if let Ok(metadata) = path.metadata() {',
  '                stats.total_bytes += metadata.len();',
  '            }',
  '',
  '            if let Some(ext) = path.extension().and_then(|e| e.to_str()) {',
  '                *stats.by_extension',
  '                    .entry(ext.to_string())',
  '                    .or_insert(0) += 1;',
  '            }',
  '        } else if path.is_dir() {',
  '            stats.total_dirs += 1;',
  '        }',
  '    }',
  '',
  '    pb.finish_with_message("Done!");',
  '',
  '    // Output stats',
  '    match format {',
  '        OutputFormat::Json =&gt; {',
  '            println!("{}", serde_json::to_string_pretty(&amp;stats)?);',
  '        }',
  '        OutputFormat::Text =&gt; {',
  '            print_header("Directory Statistics");',
  '            println!("  Files:       {}", stats.total_files.to_string().cyan());',
  '            println!("  Directories: {}", stats.total_dirs.to_string().cyan());',
  '            println!("  Total size:  {}", format_bytes(stats.total_bytes).cyan());',
  '            println!();',
  '            print_header("Files by Extension");',
  '            let mut sorted: Vec&lt;_&gt; = stats.by_extension.iter().collect();',
  '            sorted.sort_by(|a, b| b.1.cmp(a.1));',
  '            for (ext, count) in sorted.iter().take(15) {',
  '                println!("  .{:&lt;12} {}", ext.yellow(), count);',
  '            }',
  '        }',
  '        OutputFormat::Yaml =&gt; {',
  '            println!("{}", serde_yaml::to_string(&amp;stats)?);',
  '        }',
  '    }',
  '',
  '    Ok(())',
  '}',
  '',
  '#[derive(Default, serde::Serialize)]',
  'struct FileStats {',
  '    total_files: usize,',
  '    total_dirs: usize,',
  '    total_bytes: u64,',
  '    by_extension: std::collections::HashMap&lt;String, usize&gt;,',
  '}',
  '',
  'fn format_bytes(bytes: u64) -&gt; String {',
  '    const UNITS: &amp;[&amp;str] = &amp;["B", "KB", "MB", "GB", "TB"];',
  '    let mut size = bytes as f64;',
  '    let mut unit_idx = 0;',
  '    while size &gt;= 1024.0 &amp;&amp; unit_idx &lt; UNITS.len() - 1 {',
  '        size /= 1024.0;',
  '        unit_idx += 1;',
  '    }',
  '    format!("{:.1} {}", size, UNITS[unit_idx])',
  '}'
].join('\n');

const codeBlock9 = [
  'use thiserror::Error;',
  '',
  '#[derive(Error, Debug)]',
  'enum FxrError {',
  '    #[error("Unsupported file format: {0}")]',
  '    UnsupportedFormat(String),',
  '',
  '    #[error("Pattern compilation failed: {0}")]',
  '    InvalidPattern(#[from] regex::Error),',
  '',
  '    #[error("File not found: {path}")]',
  '    FileNotFound {',
  '        path: String,',
  '        #[source]',
  '        source: std::io::Error,',
  '    },',
  '',
  '    #[error("Conversion failed: {from_format} -> {to_format}")]',
  '    ConversionFailed {',
  '        from_format: String,',
  '        to_format: String,',
  '        #[source]',
  '        source: anyhow::Error,',
  '    },',
  '}'
].join('\n');

const codeBlock10 = [
  'use anyhow::{Context, Result, bail, ensure};',
  '',
  'fn process_config(path: &amp;str) -&gt; Result&lt;Config&gt; {',
  '    // bail! returns an error immediately',
  '    ensure!(',
  '        Path::new(path).exists(),',
  '        "Config file does not exist: {}",',
  '        path',
  '    );',
  '',
  '    let contents = fs::read_to_string(path)',
  '        .with_context(|| format!("Could not read config file: {}", path))?;',
  '',
  '    let config: Config = serde_json::from_str(&amp;contents)',
  '        .with_context(|| format!("Config file contains invalid JSON: {}", path))?;',
  '',
  '    // Validate config',
  '    if config.max_depth == 0 {',
  '        bail!("max_depth must be greater than 0");',
  '    }',
  '',
  '    Ok(config)',
  '}'
].join('\n');

const codeBlock11 = [
  'fn cmd_grep(',
  '    pattern: &amp;str,',
  '    dir: &amp;str,',
  '    include: Option&lt;&amp;str&gt;,',
  '    context: usize,',
  '    verbose: bool,',
  '    format: &amp;OutputFormat,',
  ') -&gt; Result&lt;()&gt; {',
  '    let re = Regex::new(pattern)',
  '        .with_context(|| format!("Invalid regex: {}", pattern))?;',
  '',
  "    let extensions: Option&lt;Vec&lt;&amp;str&gt;&gt; = include.map(|s| s.split(',').collect());",
  '',
  '    let mut results: Vec&lt;GrepMatch&gt; = Vec::new();',
  '    let mut files_searched = 0u64;',
  '',
  '    let spinner = ProgressBar::new_spinner();',
  '    spinner.set_style(',
  '        ProgressStyle::default_spinner()',
  '            .template("{spinner:.green} Searching... {msg}")?',
  '    );',
  '',
  '    for entry in WalkDir::new(dir)',
  '        .into_iter()',
  '        .filter_map(|e| e.ok())',
  '        .filter(|e| e.path().is_file())',
  '    {',
  '        let path = entry.path();',
  '',
  '        // Filter by extension',
  '        if let Some(ref exts) = extensions {',
  '            match path.extension().and_then(|e| e.to_str()) {',
  '                Some(ext) if exts.contains(&amp;ext) =&gt; {}',
  '                _ =&gt; continue,',
  '            }',
  '        }',
  '',
  '        // Skip binary files',
  '        let contents = match fs::read_to_string(path) {',
  '            Ok(c) =&gt; c,',
  "            Err(_) =&gt; continue, // Silently skip files we can't read as UTF-8",
  '        };',
  '',
  '        files_searched += 1;',
  '        spinner.set_message(format!("{} files", files_searched));',
  '',
  '        for (line_idx, line) in contents.lines().enumerate() {',
  '            if re.is_match(line) {',
  '                results.push(GrepMatch {',
  '                    path: path.display().to_string(),',
  '                    line_number: line_idx + 1,',
  '                    line: line.to_string(),',
  '                });',
  '            }',
  '        }',
  '    }',
  '',
  '    spinner.finish_and_clear();',
  '',
  '    match format {',
  '        OutputFormat::Json =&gt; {',
  '            println!("{}", serde_json::to_string_pretty(&amp;results)?);',
  '        }',
  '        OutputFormat::Text =&gt; {',
  '            for m in &amp;results {',
  '                print_match(&amp;m.path, m.line_number, &amp;m.line, &amp;re);',
  '            }',
  '            if verbose {',
  '                eprintln!(',
  '                    "\\n{} matches in {} files ({} files searched)",',
  '                    results.len().to_string().green().bold(),',
  '                    results.iter()',
  '                        .map(|m| &amp;m.path)',
  '                        .collect::&lt;std::collections::HashSet&lt;_&gt;&gt;()',
  '                        .len(),',
  '                    files_searched,',
  '                );',
  '            }',
  '        }',
  '        OutputFormat::Yaml =&gt; {',
  '            println!("{}", serde_yaml::to_string(&amp;results)?);',
  '        }',
  '    }',
  '',
  '    Ok(())',
  '}',
  '',
  '#[derive(serde::Serialize)]',
  'struct GrepMatch {',
  '    path: String,',
  '    line_number: usize,',
  '    line: String,',
  '}'
].join('\n');

const codeBlock12 = [
  '#[cfg(test)]',
  'mod tests {',
  '    use super::*;',
  '',
  '    #[test]',
  '    fn test_format_bytes() {',
