  '    }',
  '}'
].join('\n');

const codeBlock13 = [
  '// tests/integration_test.rs',
  'use assert_cmd::Command;',
  'use predicates::prelude::*;',
  'use tempfile::TempDir;',
  'use std::fs;',
  '',
  '#[test]',
  'fn test_find_command() {',
  '    let dir = TempDir::new().unwrap();',
  '    fs::write(dir.path().join("hello.rs"), "fn main() {}").unwrap();',
  '    fs::write(dir.path().join("hello.txt"), "hello world").unwrap();',
  '',
  '    Command::cargo_bin("fxr")',
  '        .unwrap()',
  '        .args(&amp;["find", r"\\.rs$", "-d", dir.path().to_str().unwrap()])',
  '        .assert()',
  '        .success()',
  '        .stdout(predicate::str::contains("hello.rs"));',
  '}',
  '',
  '#[test]',
  'fn test_convert_json_to_yaml() {',
  '    let dir = TempDir::new().unwrap();',
  '    let input = dir.path().join("data.json");',
  '    let output = dir.path().join("data.yaml");',
  '',
  '    fs::write(&amp;input, r#"{"name": "fxr", "version": 1}"#).unwrap();',
  '',
  '    Command::cargo_bin("fxr")',
  '        .unwrap()',
  '        .args(&amp;[',
  '            "convert",',
  '            input.to_str().unwrap(),',
  '            "-o", output.to_str().unwrap(),',
  '        ])',
  '        .assert()',
  '        .success();',
  '',
  '    let yaml_content = fs::read_to_string(&amp;output).unwrap();',
  '    assert!(yaml_content.contains("name: fxr"));',
  '    assert!(yaml_content.contains("version: 1"));',
  '}',
  '',
  '#[test]',
  'fn test_invalid_regex_shows_error() {',
  '    Command::cargo_bin("fxr")',
  '        .unwrap()',
  '        .args(&amp;["find", "[invalid"])',
  '        .assert()',
