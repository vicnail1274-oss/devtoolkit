      sha256 "YOUR_SHA256_HERE"
    end
  end

  on_linux do
    url "https://github.com/yourusername/fxr/releases/download/v0.1.0/fxr-linux-amd64.tar.gz"
    sha256 "YOUR_SHA256_HERE"
  end

  def install
    bin.install "fxr"
  end
end</code></pre>

