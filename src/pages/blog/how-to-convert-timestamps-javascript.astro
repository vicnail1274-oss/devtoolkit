import BlogLayout from '../../layouts/BlogLayout.astro';

const codeDateBasics = [
  '// Create Date objects',
  'const now = new Date();                    // Current time',
  'const fromUnix = new Date(1711000000000);  // From Unix ms',
  'const fromISO = new Date("2024-03-21T12:00:00Z");',
  'const fromParts = new Date(2024, 2, 21, 12, 0, 0); // Month is 0-indexed!',
  '',
  '// Get current Unix timestamp (milliseconds)',
  'Date.now();          // 1711000000000',
  '',
  '// Get current Unix timestamp (seconds)',
  'Math.floor(Date.now() / 1000);  // 1711000000',
  '',
  '// Convert Date to Unix seconds',
  'Math.floor(new Date("2024-03-21").getTime() / 1000);'
].join('\n');

const codeUnixConvert = [
  '// Unix timestamp (seconds) → human-readable',
  'const unixSeconds = 1711000000;',
  'const date = new Date(unixSeconds * 1000);  // Must multiply by 1000!',
  '',
  'date.toISOString();          // "2024-03-21T06:13:20.000Z"',
  'date.toLocaleDateString();   // "3/21/2024" (locale-dependent)',
  'date.toLocaleString();       // "3/21/2024, 6:13:20 AM"',
  '',
  '// Unix timestamp (milliseconds) → human-readable',
  'const unixMs = 1711000000000;',
  'const date2 = new Date(unixMs);  // No multiplication needed',
  'date2.toISOString();  // "2024-03-21T06:13:20.000Z"',
  '',
  '// Quick check: Unix seconds are ~10 digits, Unix ms are ~13 digits',
  '1711000000    // seconds (10 digits)',
  '1711000000000 // milliseconds (13 digits)'
].join('\n');

const codeISO8601 = [
  '// ISO 8601 formats',
  '"2024-03-21"                    // Date only',
  '"2024-03-21T06:13:20"           // Local datetime (no timezone)',
  '"2024-03-21T06:13:20Z"          // UTC (Z suffix)',
  '"2024-03-21T06:13:20+08:00"     // With timezone offset',
  '"2024-03-21T06:13:20.000Z"      // With milliseconds',
  '',
  '// Always use ISO 8601 when storing/transmitting dates',
  'const stored = new Date().toISOString();  // "2024-03-21T06:13:20.000Z"',
  '',
  '// Parse ISO string',
  'const d = new Date("2024-03-21T06:13:20Z");',
  'd.getTime();  // 1711001600000 (milliseconds)',
  '',
  '// Avoid ambiguous formats — these may parse differently per browser/environment',
  'new Date("03/21/2024");  // Ambiguous',
  'new Date("21-03-2024");  // May fail in some engines'
].join('\n');

const codeTimezone = [
  '// Intl.DateTimeFormat — the modern way to format with timezones',
  'const date = new Date("2024-03-21T06:13:20Z");',
  '',
  '// Format in a specific timezone',
  'const formatter = new Intl.DateTimeFormat("en-US", {',
  '  timeZone: "America/New_York",',
  '  year: "numeric",',
  '  month: "long",',
  '  day: "numeric",',
  '  hour: "2-digit",',
  '  minute: "2-digit",',
  '  timeZoneName: "short"',
  '});',
  'formatter.format(date);',
  '// "March 21, 2024 at 02:13 AM EDT"',
  '',
  '// Get UTC components (avoid local timezone surprises)',
  'date.getUTCFullYear()  // 2024',
  'date.getUTCMonth()     // 2 (March — remember: 0-indexed)',
  'date.getUTCDate()      // 21',
  'date.getUTCHours()     // 6',
  '',
  '// Common timezone IDs',
  '// "UTC", "America/New_York", "America/Los_Angeles",',
  '// "Europe/London", "Asia/Tokyo", "Asia/Shanghai"'
].join('\n');

const codeDateFns = [
  'npm install date-fns',
  '',
  '// date-fns — functional, tree-shakeable, no classes',
  'import { format, parseISO, fromUnixTime, formatDistanceToNow } from \'date-fns\';',
  '',
  '// Format a date',
  'format(new Date(), "yyyy-MM-dd HH:mm:ss");  // "2024-03-21 06:13:20"',
  '',
  '// Parse ISO string',
  'const d = parseISO("2024-03-21T06:13:20Z");',
  '',
  '// Convert Unix timestamp (seconds) to Date',
  'const d2 = fromUnixTime(1711000000);',
  '',
  '// Relative time',
  'formatDistanceToNow(new Date("2024-03-21"), { addSuffix: true });',
  '// "3 days ago"'
].join('\n');

const codeDayjs = [
  'npm install dayjs',
  '',
  '// dayjs — lightweight (2KB), Moment-compatible API',
  'import dayjs from \'dayjs\';',
  'import utc from \'dayjs/plugin/utc\';',
  'import timezone from \'dayjs/plugin/timezone\';',
  '',
  'dayjs.extend(utc);',
  'dayjs.extend(timezone);',
  '',
  '// Parse and format',
  'dayjs().format("YYYY-MM-DD");         // "2024-03-21"',
  'dayjs(1711000000000).toISOString();   // "2024-03-21T06:13:20.000Z"',
  '',
  '// Unix timestamp (seconds)',
  'dayjs.unix(1711000000).format();      // "2024-03-21T06:13:20+00:00"',
  '',
  '// With timezone',
  'dayjs("2024-03-21T06:13:20Z")',
  '  .tz("America/New_York")',
  '  .format("MMM D, YYYY h:mm A z");   // "Mar 21, 2024 2:13 AM EDT"'
].join('\n');

const codeCommonConversions = [
  '// Cheat sheet: most common timestamp conversions',
  '',
  '// Current Unix seconds',
  'Math.floor(Date.now() / 1000)',
  '',
  '// Current Unix ms',
  'Date.now()',
  '',
  '// Unix seconds → ISO string',
  'new Date(unix * 1000).toISOString()',
  '',
  '// ISO string → Unix seconds',
  'Math.floor(new Date(isoString).getTime() / 1000)',
  '',
  '// Date object → ISO string',
  'date.toISOString()',
  '',
  '// ISO string → Date object',
  'new Date(isoString)',
  '',
  '// Date → start of day (midnight UTC)',
  'new Date(date.toISOString().slice(0, 10) + "T00:00:00Z")',
  '',
  '// Add N days to a date',
  'new Date(date.getTime() + n * 24 * 60 * 60 * 1000)'
].join('\n');
