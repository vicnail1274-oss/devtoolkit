  '    })',
  '  ]',
  '};',
  '',
  '# Run',
  'npx postcss src/styles.css -o dist/styles.min.css'
].join('\n');

const codeCleanCss = [
  '# Install clean-css CLI',
  'npm install -g clean-css-cli',
  '',
  '# Minify a single file',
  'cleancss -o output.min.css input.css',
  '',
  '# Minify multiple files into one',
  'cleancss -o bundle.min.css reset.css base.css components.css',
  '',
  '# With source map',
  'cleancss --source-map -o output.min.css input.css'
].join('\n');

const codeWebpack = [
  '// webpack.config.js',
  'const MiniCssExtractPlugin = require(\'mini-css-extract-plugin\');',
  'const CssMinimizerPlugin = require(\'css-minimizer-webpack-plugin\');',
  '',
  'module.exports = {',
  '  mode: \'production\',',
  '  plugins: [new MiniCssExtractPlugin()],',
  '  optimization: {',
  '    minimizer: [',
  '      `...`,   // keep existing JS minimizer',
  '      new CssMinimizerPlugin(),',
  '    ],',
  '  },',
  '};'
].join('\n');

const codeVite = [
  '// vite.config.js — Vite uses esbuild by default, but you can override',
  'import { defineConfig } from \'vite\';',
  '',
  'export default defineConfig({',
  '  build: {',
  '    cssMinify: \'lightningcss\',  // faster than esbuild for CSS',
  '    // or cssMinify: \'esbuild\'  (default)',
  '  }',
  '});'
].join('\n');

const codeCritical = [
  '&lt;head&gt;',
  '  &lt;!-- Critical CSS — inlined, renders above-the-fold content immediately --&gt;',
  '  &lt;style&gt;',
  '    body{margin:0;font-family:system-ui}.header{display:flex;padding:16px}',
  '    .hero{font-size:clamp(32px,5vw,56px);margin-top:80px}',
  '  &lt;/style&gt;',
  '',
  '  &lt;!-- Full CSS loaded asynchronously --&gt;',
  '  &lt;link rel="preload" href="/styles.min.css" as="style"',
  '        onload="this.onload=null;this.rel=\'stylesheet\'"&gt;',
  '  &lt;noscript&gt;&lt;link rel="stylesheet" href="/styles.min.css"&gt;&lt;/noscript&gt;',
  '&lt;/head&gt;'
].join('\n');
