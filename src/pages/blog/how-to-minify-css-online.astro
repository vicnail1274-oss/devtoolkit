].join('\n');

const codeCssnano = [
  'npm install cssnano postcss postcss-cli --save-dev',
  '',
  '# Create postcss.config.js',
  'module.exports = {',
  '  plugins: [',
  '    require(\'cssnano\')({',
  '      preset: [\'default\', {',
  '        discardComments: { removeAll: true },',
