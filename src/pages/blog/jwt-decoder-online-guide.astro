const codeJwtStructure = [
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9',
  '.',
  'eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkFsaWNlIiwiaWF0IjoxNzExMDAwMDAwLCJleHAiOjE3MTEwODY0MDB9',
  '.',
  'SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c'
].join('');

const codeHeader = [
  '{',
  '  "alg": "HS256",',
  '  "typ": "JWT"',
  '}'
].join('\n');

const codePayload = [
  '{',
  '  "sub": "1234567890",',
  '  "name": "Alice",',
  '  "iat": 1711000000,',
  '  "exp": 1711086400,',
  '  "iss": "https://auth.example.com",',
  '  "aud": "https://api.example.com"',
  '}'
].join('\n');

const codeBase64Decode = [
  '// Decode JWT payload in the browser (never for verification!)',
  'function decodeJwtPayload(token) {',
  '  const base64Url = token.split(\'.\')[1];',
  '  const base64 = base64Url.replace(/-/g, \'+\').replace(/_/g, \'/\');',
  '  const jsonPayload = decodeURIComponent(',
  '    atob(base64)',
  '      .split(\'\')',
  '      .map(c => \'%\' + (\'00\' + c.charCodeAt(0).toString(16)).slice(-2))',
  '      .join(\'\')',
  '  );',
  '  return JSON.parse(jsonPayload);',
  '}',
  '',
  'const payload = decodeJwtPayload(token);',
  'console.log(payload.exp);  // Unix timestamp',
  'console.log(new Date(payload.exp * 1000));  // Human-readable'
].join('\n');

const codeVerify = [
  '// Node.js — verify signature with jsonwebtoken',
  'const jwt = require(\'jsonwebtoken\');',
  '',
  'try {',
  '  const decoded = jwt.verify(token, process.env.JWT_SECRET);',
  '  console.log(decoded.sub);   // User ID',
  '  console.log(decoded.exp);   // Expiry',
  '} catch (err) {',
  '  if (err.name === \'TokenExpiredError\') {',
  '    console.error(\'Token has expired\');',
  '  } else if (err.name === \'JsonWebTokenError\') {',
  '    console.error(\'Invalid signature\');',
  '  }',
  '}'
].join('\n');

const codeExpCheck = [
  '// Check if a token is expired (client-side, no verification)',
  'function isTokenExpired(token) {',
  '  const { exp } = decodeJwtPayload(token);',
  '  return Date.now() >= exp * 1000;',
  '}',
  '',
  '// Check time remaining',
  'function tokenSecondsRemaining(token) {',
  '  const { exp } = decodeJwtPayload(token);',
  '  return Math.floor((exp * 1000 - Date.now()) / 1000);',
  '}'
].join('\n');
