---
import ToolLayout from '../layouts/ToolLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { freeTools, proTools, categories } from '../data/tools';

const displayCategories = categories.filter(c => c !== 'All');

// Featured tools (most popular / high-value)
const featuredSlugs = ['json-formatter', 'regex-tester', 'jwt-decoder', 'base64', 'cron-generator', 'password-generator'];
const featuredTools = featuredSlugs.map(s => freeTools.find(t => t.slug === s)).filter(Boolean);

// New tools (recently added)
const newSlugs = ['code-screenshot', 'og-image-preview', 'meta-tag-generator', 'favicon-generator', 'github-readme-generator', 'color-palette-generator'];
const newTools = newSlugs.map(s => freeTools.find(t => t.slug === s)).filter(Boolean);

// Recommended (editor picks for typical workflow)
const recommendedSlugs = ['api-tester', 'diff-checker', 'markdown-preview-editor', 'json-schema-generator', 'sql-formatter', 'qr-code-generator'];
const recommendedTools = recommendedSlugs.map(s => freeTools.find(t => t.slug === s)).filter(Boolean);

const popularSearches = [
  { label: 'JSON', query: 'json' },
  { label: 'Regex', query: 'regex' },
  { label: 'Base64', query: 'base64' },
  { label: 'Hash', query: 'hash' },
  { label: 'UUID', query: 'uuid' },
  { label: 'JWT', query: 'jwt' },
  { label: 'Cron', query: 'cron' },
  { label: 'Color', query: 'color' },
];
---

<ToolLayout title="Free Developer Tools" description="Free online developer tools for AI/LLM engineers. No signup required.">
  <!-- Hero Section with Integrated Search -->
  <div class="text-center mb-10">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-sm font-medium mb-6">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
      </span>
      {freeTools.length}+ Free Tools &middot; No Signup Required
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-5 leading-tight">
      <span class="bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent">
        Developer Tools
      </span>
      <br />
      <span class="text-gray-900 dark:text-gray-100">That Just Work</span>
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mb-8">
      Free, fast, and privacy-friendly tools for developers and AI engineers.
      No signup, no tracking &mdash; everything runs in your browser.
    </p>

    <!-- Hero Search Bar -->
    <div class="max-w-2xl mx-auto mb-5">
      <div class="relative group">
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="hero-search"
          placeholder="Search tools... (e.g. JSON, regex, hash)"
          class="w-full pl-14 pr-24 py-4 bg-white dark:bg-gray-900 border-2 border-gray-200 dark:border-gray-700 rounded-2xl text-base focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-all duration-200 shadow-lg shadow-gray-200/50 dark:shadow-gray-900/50"
        />
        <kbd class="hidden sm:inline-flex absolute right-4 top-1/2 -translate-y-1/2 items-center gap-1 px-2.5 py-1 bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-500 rounded-lg text-xs font-mono border border-gray-200 dark:border-gray-700">
          <span class="text-sm">/</span>
        </kbd>
      </div>
    </div>

    <!-- Popular Searches -->
    <div class="flex flex-wrap justify-center gap-2 mb-8" id="popular-searches">
      <span class="text-xs text-gray-400 dark:text-gray-500 self-center mr-1">Popular:</span>
      {popularSearches.map((item) => (
        <button
          data-search-query={item.query}
          class="popular-search-btn px-3 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-primary-100 hover:text-primary-700 dark:hover:bg-primary-900/40 dark:hover:text-primary-400 transition-all duration-200 cursor-pointer"
        >
          {item.label}
        </button>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-500 dark:text-gray-400 mb-8">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        100% Free
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        No Account Needed
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Runs In Your Browser
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Open Source
      </span>
    </div>
  </div>

  <!-- Social Proof: Stats Bar -->
  <div class="mb-14">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="relative overflow-hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center group hover:border-primary-300 dark:hover:border-primary-700 transition-colors duration-200">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-50/50 to-transparent dark:from-primary-950/30 dark:to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{freeTools.length}+</div>
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Free Tools</div>
        </div>
      </div>
      <div class="relative overflow-hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center group hover:border-primary-300 dark:hover:border-primary-700 transition-colors duration-200">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-50/50 to-transparent dark:from-emerald-950/30 dark:to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative">
          <div class="text-3xl font-bold text-emerald-600 dark:text-emerald-400">10K+</div>
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Monthly Users</div>
        </div>
      </div>
      <div class="relative overflow-hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center group hover:border-primary-300 dark:hover:border-primary-700 transition-colors duration-200">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent dark:from-blue-950/30 dark:to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative">
          <div class="text-3xl font-bold text-blue-600 dark:text-blue-400">100%</div>
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Client-Side</div>
        </div>
      </div>
      <div class="relative overflow-hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center group hover:border-primary-300 dark:hover:border-primary-700 transition-colors duration-200">
        <div class="absolute inset-0 bg-gradient-to-br from-amber-50/50 to-transparent dark:from-amber-950/30 dark:to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative">
          <div class="text-3xl font-bold text-amber-600 dark:text-amber-400">95+</div>
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Lighthouse Score</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Featured Tools -->
  <div class="mb-14">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <span class="text-sm font-semibold">Featured</span>
        </div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Most Popular</h2>
      </div>
      <a href="#all-tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline font-medium hidden sm:inline-flex items-center gap-1">
        View all
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredTools.map((tool) => (
        <ToolCard {...tool} />
      ))}
    </div>
  </div>

  <!-- New Tools -->
  <div class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        <span class="text-sm font-semibold">New</span>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Recently Added</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {newTools.map((tool) => (
        <ToolCard {...tool} />
      ))}
    </div>
  </div>

  <!-- Recommended Tools -->
  <div class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="text-sm font-semibold">Recommended</span>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Editor's Picks</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {recommendedTools.map((tool) => (
        <ToolCard {...tool} />
      ))}
    </div>
  </div>

  <!-- All Tools Section -->
  <div id="all-tools" class="pt-8 border-t border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">All Tools</h2>
      <span class="text-sm text-gray-400 dark:text-gray-500" id="tool-count-label">
        <span id="tool-count">{freeTools.length}</span> tools
      </span>
    </div>

    <!-- Search -->
    <div class="max-w-xl mx-auto mb-6">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="tool-search"
          placeholder="Search tools... (e.g. JSON, regex, hash)"
          class="w-full pl-12 pr-4 py-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all duration-200"
        />
      </div>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" id="category-filter">
      <button
        data-category="All"
        class="category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 bg-primary-600 text-white"
      >
        All
      </button>
      {displayCategories.map((cat) => (
        <button
          data-category={cat}
          class="category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Tool Grid -->
    <div id="tool-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {freeTools.map((tool) => (
        <div class="tool-item" data-title={tool.title.toLowerCase()} data-description={tool.description.toLowerCase()} data-category={tool.category}>
          <ToolCard {...tool} />
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-gray-400 dark:text-gray-500 text-lg">No tools found matching your search.</p>
    </div>
  </div>

  <!-- Pro AI Tools Section -->
  <div class="mt-16 pt-12 border-t border-gray-200 dark:border-gray-700">
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400 text-sm font-medium mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        PRO
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">
        <span class="bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent">
          AI-Powered Tools
        </span>
      </h2>
      <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
        Supercharge your workflow with AI. Code review, documentation, and SQL — all powered by advanced language models.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {proTools.map((tool) => (
        <a
          href={tool.href}
          class="group relative block bg-white dark:bg-gray-900 rounded-xl shadow-sm hover:shadow-lg border border-primary-200 dark:border-primary-800 p-6 transition-all duration-200 hover:-translate-y-1"
        >
          <div class="absolute top-3 right-3">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gradient-to-r from-primary-600 to-primary-500 text-white text-xs font-bold">
              PRO
            </span>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-primary-50 dark:bg-primary-950 rounded-xl flex items-center justify-center text-2xl group-hover:scale-110 transition-transform duration-200">
              {tool.icon}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-200 truncate">
                {tool.title}
              </h3>
              <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full bg-primary-50 dark:bg-primary-950 text-primary-600 dark:text-primary-400 mb-2">
                {tool.category}
              </span>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
                {tool.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-6">
      <a href="/pricing" data-track-cta="hero-start-free-trial" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-xl transition-colors duration-200">
        Start Free Trial — $9.99/mo
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>

  <!-- Developer Testimonials -->
  <div class="mt-16 pt-12 border-t border-gray-200 dark:border-gray-700">
    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">
        <span class="text-gray-900 dark:text-gray-100">Trusted by Developers</span>
      </h2>
      <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
        Join thousands of developers who use DevToolkit every day.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 relative">
        <svg class="absolute top-4 right-4 w-8 h-8 text-primary-100 dark:text-primary-900/40" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
        <div class="flex items-center gap-1 mb-3">
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        </div>
        <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
          "Finally, a tool site that doesn't make me create an account. The JSON formatter and JWT decoder are my daily drivers. Blazing fast."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-sm font-bold">A</div>
          <div>
            <div class="text-sm font-semibold text-gray-900 dark:text-gray-100">Alex Chen</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">Full-Stack Developer</div>
          </div>
        </div>
