  <!-- Search + Category Filter + Hero Search Script -->
  <script is:inline>
    var heroSearch = document.getElementById('hero-search');
    var searchInput = document.getElementById('tool-search');
    var emptyState = document.getElementById('empty-state');
    var toolCount = document.getElementById('tool-count');
    var toolItems = document.querySelectorAll('.tool-item');
    var categoryBtns = document.querySelectorAll('.category-btn');
    var popularBtns = document.querySelectorAll('.popular-search-btn');

    var activeCategory = 'All';

    function filterTools() {
      var query = (searchInput?.value || '').toLowerCase().trim();
      var visible = 0;

      toolItems.forEach(function(item) {
        var title = item.dataset.title || '';
        var desc = item.dataset.description || '';
        var cat = item.dataset.category || '';
        var matchesSearch = !query || title.includes(query) || desc.includes(query);
        var matchesCategory = activeCategory === 'All' || cat === activeCategory;
        var show = matchesSearch && matchesCategory;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
      if (toolCount) toolCount.textContent = visible.toString();
    }

    searchInput?.addEventListener('input', filterTools);

    categoryBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeCategory = btn.dataset.category || 'All';
        categoryBtns.forEach(function(b) {
          if (b.dataset.category === activeCategory) {
            b.className = 'category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 bg-primary-600 text-white';
          } else {
            b.className = 'category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700';
          }
        });
        filterTools();
      });
    });

    function scrollToToolsAndSearch(query) {
      var allToolsSection = document.getElementById('all-tools');
      if (allToolsSection) {
        allToolsSection.scrollIntoView({ behavior: 'smooth' });
      }
      if (searchInput) {
        searchInput.value = query;
        searchInput.dispatchEvent(new Event('input'));
        setTimeout(function() { searchInput.focus(); }, 400);
      }
    }

    if (heroSearch) {
      heroSearch.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          scrollToToolsAndSearch(heroSearch.value);
        }
      });
      heroSearch.addEventListener('input', function() {
        if (heroSearch.value.length >= 2) {
          scrollToToolsAndSearch(heroSearch.value);
        }
      });
    }

    popularBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var query = btn.dataset.searchQuery || '';
        if (heroSearch) heroSearch.value = query;
        scrollToToolsAndSearch(query);
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey) {
        var tag = (document.activeElement || {}).tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
        e.preventDefault();
        if (heroSearch) heroSearch.focus();
      }
    });
  </script>
