---
import EmailPopup from '../components/EmailPopup';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Analytics Dashboard | DevToolkit</title>
    <meta name="description" content="DevToolkit usage analytics — tool usage, page views, and conversion tracking." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; }
      .stat-card {
        background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(139,92,246,0.1));
        border: 1px solid rgba(59,130,246,0.2);
        border-radius: 12px;
        padding: 1.5rem;
      }
      .stat-value { font-size: 2rem; font-weight: 700; color: #3b82f6; }
      .stat-label { font-size: 0.875rem; color: #9ca3af; margin-top: 0.25rem; }
      .chart-bar {
        background: linear-gradient(to right, #3b82f6, #8b5cf6);
        border-radius: 4px;
        min-width: 2px;
        transition: width 0.3s ease;
      }
      .table-row:hover { background: rgba(59,130,246,0.05); }
      .loading-spinner {
        border: 3px solid rgba(59,130,246,0.2);
        border-top-color: #3b82f6;
        border-radius: 50%;
        width: 32px; height: 32px;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .period-btn { padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.875rem; cursor: pointer; transition: all 0.2s; border: 1px solid transparent; }
      .period-btn.active { background: #3b82f6; color: white; }
      .period-btn:not(.active) { background: rgba(59,130,246,0.1); color: #9ca3af; }
      .period-btn:not(.active):hover { background: rgba(59,130,246,0.2); }
    </style>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-gray-900/80 backdrop-blur-lg border-b border-gray-800">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">&lt;/&gt;</span>
          </div>
          <span class="text-xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">DevToolkit</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Tools</a>
          <a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Blog</a>
          <span class="text-sm font-medium text-blue-400">Analytics</span>
        </div>
      </nav>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Title + Period Selector -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold">Analytics Dashboard</h1>
          <p class="text-gray-400 text-sm mt-1">Tool usage, page views, and conversion tracking</p>
        </div>
        <div class="flex gap-2" id="period-selector">
          <button class="period-btn" data-days="1">Today</button>
          <button class="period-btn active" data-days="7">7 Days</button>
          <button class="period-btn" data-days="30">30 Days</button>
          <button class="period-btn" data-days="90">90 Days</button>
        </div>
      </div>

      <!-- Loading State -->
      <div id="loading" class="flex items-center justify-center py-20">
        <div class="loading-spinner"></div>
        <span class="ml-3 text-gray-400">Loading analytics...</span>
      </div>

      <!-- Error State -->
      <div id="error" class="hidden text-center py-20">
        <p class="text-red-400 text-lg mb-2">Unable to load analytics</p>
        <p class="text-gray-500 text-sm" id="error-msg"></p>
        <p class="text-gray-600 text-xs mt-4">Make sure the ANALYTICS KV namespace is bound in wrangler.toml</p>
      </div>

      <!-- Dashboard Content (hidden until data loads) -->
      <div id="dashboard" class="hidden space-y-8">
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="stat-card">
            <div class="stat-value" id="total-views">0</div>
            <div class="stat-label">Page Views</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="total-tools" style="color: #8b5cf6;">0</div>
            <div class="stat-label">Tool Uses</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="total-ctas" style="color: #10b981;">0</div>
            <div class="stat-label">CTA Clicks</div>
          </div>
        </div>

        <!-- Daily Chart -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h2 class="text-lg font-semibold mb-4">Daily Traffic</h2>
          <div id="daily-chart" class="space-y-2"></div>
        </div>

        <!-- Two Column: Top Tools + Top CTAs -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Top Tools -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-lg font-semibold mb-4">Top Tools</h2>
            <div id="top-tools" class="space-y-1"></div>
            <p id="no-tools" class="hidden text-gray-500 text-sm py-4 text-center">No tool usage data yet</p>
          </div>

          <!-- Top CTAs -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-lg font-semibold mb-4">CTA Performance</h2>
            <div id="top-ctas" class="space-y-1"></div>
            <p id="no-ctas" class="hidden text-gray-500 text-sm py-4 text-center">No CTA click data yet</p>
          </div>
        </div>
      </div>
    </main>

    <script is:inline>
      let currentDays = 7;

      async function loadAnalytics(days) {
        currentDays = days;
        const loading = document.getElementById('loading');
        const error = document.getElementById('error');
        const dashboard = document.getElementById('dashboard');

        loading.classList.remove('hidden');
        error.classList.add('hidden');
        dashboard.classList.add('hidden');

        // Update active button
        document.querySelectorAll('.period-btn').forEach(btn => {
          btn.classList.toggle('active', parseInt(btn.dataset.days) === days);
        });

        try {
          const res = await fetch('/api/analytics/query?days=' + days);
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          if (!data.ok) throw new Error(data.error || 'Unknown error');

          renderDashboard(data);
          loading.classList.add('hidden');
          dashboard.classList.remove('hidden');
        } catch (e) {
          loading.classList.add('hidden');
          error.classList.remove('hidden');
          document.getElementById('error-msg').textContent = e.message;
        }
      }

      function renderDashboard(data) {
        // Summary totals
        let totalViews = 0, totalTools = 0, totalCtas = 0;
        for (const date of data.dates) {
          const d = data.dailyTotals[date];
          if (d) {
            totalViews += d.page_view || 0;
            totalTools += d.tool_use || 0;
            totalCtas += d.cta_click || 0;
          }
        }
        document.getElementById('total-views').textContent = totalViews.toLocaleString();
        document.getElementById('total-tools').textContent = totalTools.toLocaleString();
        document.getElementById('total-ctas').textContent = totalCtas.toLocaleString();

        // Daily chart
        const chartEl = document.getElementById('daily-chart');
        chartEl.innerHTML = '';
        const maxDaily = Math.max(1, ...data.dates.map(d => {
          const t = data.dailyTotals[d];
          return t ? (t.page_view + t.tool_use + t.cta_click) : 0;
        }));

        for (const date of data.dates) {
          const t = data.dailyTotals[date] || { page_view: 0, tool_use: 0, cta_click: 0 };
          const total = t.page_view + t.tool_use + t.cta_click;
          const pct = Math.max(1, (total / maxDaily) * 100);
          const shortDate = date.slice(5); // MM-DD

          const row = document.createElement('div');
          row.className = 'flex items-center gap-3';
          row.innerHTML =
            '<span class="text-xs text-gray-500 w-14 text-right font-mono">' + shortDate + '</span>' +
            '<div class="flex-1 h-6 bg-gray-800 rounded overflow-hidden">' +
              '<div class="chart-bar h-full" style="width:' + pct + '%"></div>' +
            '</div>' +
            '<span class="text-xs text-gray-400 w-16 text-right font-mono">' + total.toLocaleString() + '</span>';
          chartEl.appendChild(row);
        }

        // Top tools
        const toolsEl = document.getElementById('top-tools');
        const noTools = document.getElementById('no-tools');
        toolsEl.innerHTML = '';
        if (data.topTools.length === 0) {
          noTools.classList.remove('hidden');
        } else {
          noTools.classList.add('hidden');
          const maxTool = data.topTools[0][1];
          data.topTools.forEach(function(item, i) {
            var slug = item[0], count = item[1];
            var pct = Math.max(2, (count / maxTool) * 100);
            var row = document.createElement('div');
            row.className = 'table-row flex items-center gap-3 py-1.5 px-2 rounded';
            row.innerHTML =
              '<span class="text-xs text-gray-500 w-6">' + (i + 1) + '.</span>' +
              '<span class="text-sm text-gray-300 flex-1 truncate">' + slug + '</span>' +
              '<div class="w-24 h-3 bg-gray-800 rounded overflow-hidden">' +
                '<div class="h-full rounded" style="width:' + pct + '%;background:linear-gradient(to right,#8b5cf6,#a78bfa)"></div>' +
              '</div>' +
              '<span class="text-xs text-gray-400 w-12 text-right font-mono">' + count + '</span>';
            toolsEl.appendChild(row);
          });
        }

        // Top CTAs
        var ctasEl = document.getElementById('top-ctas');
        var noCtas = document.getElementById('no-ctas');
        ctasEl.innerHTML = '';
        if (data.topCtas.length === 0) {
          noCtas.classList.remove('hidden');
        } else {
          noCtas.classList.add('hidden');
          var maxCta = data.topCtas[0][1];
          data.topCtas.forEach(function(item, i) {
            var label = item[0], count = item[1];
            var pct = Math.max(2, (count / maxCta) * 100);
            var row = document.createElement('div');
            row.className = 'table-row flex items-center gap-3 py-1.5 px-2 rounded';
            row.innerHTML =
              '<span class="text-xs text-gray-500 w-6">' + (i + 1) + '.</span>' +
              '<span class="text-sm text-gray-300 flex-1 truncate">' + label + '</span>' +
              '<div class="w-24 h-3 bg-gray-800 rounded overflow-hidden">' +
                '<div class="h-full rounded" style="width:' + pct + '%;background:linear-gradient(to right,#10b981,#34d399)"></div>' +
              '</div>' +
              '<span class="text-xs text-gray-400 w-12 text-right font-mono">' + count + '</span>';
            ctasEl.appendChild(row);
          });
        }
      }

      // Period selector
      document.getElementById('period-selector').addEventListener('click', function(e) {
        var btn = e.target.closest('.period-btn');
        if (btn) loadAnalytics(parseInt(btn.dataset.days));
      });

      // Initial load
      loadAnalytics(7);
    </script>
  </body>
</html>
