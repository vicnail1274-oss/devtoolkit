---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout title="Pricing - Free & Pro Plans" description="DevToolkit Pro: AI-powered developer tools, batch processing, and API access for $9.99/month.">

  <div class="max-w-5xl mx-auto">
    <!-- Hero -->
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent">
          Choose Your Plan
        </span>
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        15 free tools, forever. Unlock AI-powered tools and advanced features with Pro.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-16">

      <!-- Free Plan -->
      <div class="relative bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-2">Free</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-6">Everything you need to get started.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold">$0</span>
          <span class="text-gray-500 dark:text-gray-400">/month</span>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>15 developer tools</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Runs in your browser (private)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>No signup required</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Unlimited usage</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span class="text-gray-400 dark:text-gray-500">AI-powered tools</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span class="text-gray-400 dark:text-gray-500">Batch processing</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span class="text-gray-400 dark:text-gray-500">API access</span>
          </li>
        </ul>
        <a href="/" data-track-cta="pricing-get-started-free" class="block w-full text-center py-3 px-6 rounded-xl border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors duration-200">
          Get Started Free
        </a>
      </div>

      <!-- Pro Plan -->
      <div class="relative bg-white dark:bg-gray-900 border-2 border-primary-500 rounded-2xl p-8 shadow-lg shadow-primary-500/10">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-flex items-center gap-1 px-4 py-1 rounded-full bg-primary-600 text-white text-sm font-medium">
            Most Popular
          </span>
        </div>
        <h2 class="text-2xl font-bold mb-2">Pro</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-6">AI-powered tools for serious developers.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold">$9.99</span>
          <span class="text-gray-500 dark:text-gray-400">/month</span>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Everything in Free</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span class="font-medium">AI Code Review</span>
            <span class="text-xs px-1.5 py-0.5 rounded bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400">AI</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span class="font-medium">AI Doc Generator</span>
            <span class="text-xs px-1.5 py-0.5 rounded bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400">AI</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span class="font-medium">AI SQL Builder</span>
            <span class="text-xs px-1.5 py-0.5 rounded bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400">AI</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Batch processing (multi-file)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>REST API access</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Ad-free experience</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>7-day free trial</span>
          </li>
        </ul>
        <button
          id="checkout-btn"
          data-track-cta="pricing-start-pro-trial"
          class="block w-full text-center py-3 px-6 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-medium transition-colors duration-200 shadow-lg shadow-primary-600/25"
        >
          Start Free Trial
        </button>
        <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-3">
          Cancel anytime. No questions asked.
        </p>
      </div>
    </div>

    <!-- Feature Comparison -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-center mb-8">Feature Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full max-w-3xl mx-auto text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <th class="text-left py-3 px-4 font-medium text-gray-500 dark:text-gray-400">Feature</th>
              <th class="text-center py-3 px-4 font-medium text-gray-500 dark:text-gray-400">Free</th>
              <th class="text-center py-3 px-4 font-medium text-primary-600 dark:text-primary-400">Pro</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr>
              <td class="py-3 px-4">Developer tools (15+)</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Browser-side processing</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">AI Code Review</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">AI Documentation Generator</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">AI SQL Query Builder</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Batch processing</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">REST API access</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Ad-free experience</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Priority support</td>
              <td class="py-3 px-4 text-center text-gray-300 dark:text-gray-600">&mdash;</td>
              <td class="py-3 px-4 text-center text-green-500">&#10003;</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="group bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl">
          <summary class="flex items-center justify-between cursor-pointer p-5 font-medium">
            What happens after the 7-day free trial?
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-500 dark:text-gray-400">
            After your trial, you'll be charged $9.99/month. You can cancel anytime before the trial ends and won't be charged. All free tools remain available regardless.
          </div>
        </details>
        <details class="group bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl">
          <summary class="flex items-center justify-between cursor-pointer p-5 font-medium">
            How do the AI tools work?
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-500 dark:text-gray-400">
            AI tools use advanced language models to analyze your code, generate documentation, and build SQL queries. Your code is processed securely and never stored.
          </div>
        </details>
        <details class="group bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl">
          <summary class="flex items-center justify-between cursor-pointer p-5 font-medium">
            Can I cancel anytime?
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-500 dark:text-gray-400">
            Yes! Cancel anytime from your account settings. No questions asked, no hidden fees. Your free tools will continue to work.
          </div>
        </details>
        <details class="group bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl">
          <summary class="flex items-center justify-between cursor-pointer p-5 font-medium">
            What payment methods do you accept?
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-500 dark:text-gray-400">
            We accept all major credit cards (Visa, Mastercard, Amex) via Stripe. All payments are secure and PCI-compliant.
          </div>
        </details>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center bg-gradient-to-r from-primary-600 to-primary-500 rounded-2xl p-12 mb-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Ready to supercharge your workflow?</h2>
      <p class="text-primary-100 mb-6 max-w-xl mx-auto">Join developers using AI-powered tools to write better code, faster.</p>
      <button class="inline-flex items-center gap-2 px-8 py-3 bg-white text-primary-600 font-bold rounded-xl hover:bg-primary-50 transition-colors duration-200 shadow-lg">
        Start 7-Day Free Trial
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </button>
    </div>
  </div>

  <!-- Checkout + Auth script -->
  <script is:inline>
    // Check auth status and update UI
    async function checkAuth() {
      try {
        const res = await fetch('/api/auth/me');
        const data = await res.json();
        return data;
      } catch { return { authenticated: false }; }
    }

    // Handle checkout / login
    async function handleCheckout() {
      const auth = await checkAuth();

      if (!auth.authenticated) {
        // Not logged in → redirect to Google OAuth
        window.location.href = '/api/auth/google?redirect=/pricing';
        return;
      }

      if (auth.user?.plan === 'pro') {
        // Already Pro → open billing portal
        const res = await fetch('/api/stripe/portal', { method: 'POST' });
        const data = await res.json();
        if (data.url) window.location.href = data.url;
        return;
      }

      // Free user → create checkout session
      const res = await fetch('/api/stripe/checkout', { method: 'POST' });
      const data = await res.json();
      if (data.url) window.location.href = data.url;
    }

    document.querySelectorAll('#checkout-btn, [data-checkout]').forEach(btn => {
      btn.addEventListener('click', handleCheckout);
    });

    // Show success/cancel messages
    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      const banner = document.createElement('div');
      banner.className = 'fixed top-4 left-1/2 -translate-x-1/2 z-50 px-6 py-3 bg-green-500 text-white rounded-xl shadow-lg font-medium';
      banner.textContent = 'Welcome to Pro! Your 7-day free trial has started.';
      document.body.appendChild(banner);
      setTimeout(() => banner.remove(), 5000);
    }
  </script>
</ToolLayout>
