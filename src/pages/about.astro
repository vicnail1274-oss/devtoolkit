---
import ToolLayout from '../layouts/ToolLayout.astro';
import { freeTools, proTools } from '../data/tools';
---

<ToolLayout title="About DevToolkit" description="DevToolkit is a collection of 30+ free online developer tools. No signup, no tracking, 100% client-side.">
  <!-- Hero -->
  <div class="text-center mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      About DevToolkit
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Free developer tools that respect your privacy and just work.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-10">
    <!-- Mission -->
    <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Why DevToolkit?</h2>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
        Developers switch between dozens of utility sites every day — one for JSON formatting, another for Base64, yet another for UUID generation. Most are cluttered with ads, require signups, or send your data to a server.
      </p>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
        DevToolkit brings <strong>{freeTools.length}+ tools</strong> into one fast, clean interface. Everything runs in your browser. No backend. No tracking. No signup walls.
      </p>
    </section>

    <!-- Stats -->
    <section class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center">
        <div class="text-2xl font-bold text-primary-600 dark:text-primary-400">{freeTools.length}+</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Free Tools</div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center">
        <div class="text-2xl font-bold text-primary-600 dark:text-primary-400">0</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Dependencies</div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center">
        <div class="text-2xl font-bold text-primary-600 dark:text-primary-400">100%</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Client-Side</div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 text-center">
        <div class="text-2xl font-bold text-primary-600 dark:text-primary-400">95+</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Lighthouse Score</div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Tech Stack</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-purple-100 dark:bg-purple-900 flex items-center justify-center shrink-0">
            <span class="text-lg">🚀</span>
          </div>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Astro 4</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Static generation for instant loads</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center shrink-0">
            <span class="text-lg">⚡</span>
          </div>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Preact</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">~3KB interactive islands</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-cyan-100 dark:bg-cyan-900 flex items-center justify-center shrink-0">
            <span class="text-lg">🎨</span>
          </div>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Tailwind CSS</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Utility-first with dark mode</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-orange-100 dark:bg-orange-900 flex items-center justify-center shrink-0">
            <span class="text-lg">☁️</span>
          </div>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Cloudflare Pages</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Free global CDN hosting</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Our Principles</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 dark:text-green-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Privacy First</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Your data never leaves your browser. No server-side processing, no cookies, no tracking pixels.</div>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 dark:text-green-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Speed Over Features</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Fast page loads matter more than feature bloat. Every tool opens instantly.</div>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 dark:text-green-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Free Forever</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Core tools will always be free. No bait-and-switch, no feature gates on essentials.</div>
          </div>
        </li>
      </ul>
    </section>

    <!-- Open Source -->
    <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Open Source Utilities</h2>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
        The core utility functions that power DevToolkit are published as an open-source NPM package with <strong>zero dependencies</strong>.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="https://www.npmjs.com/package/devtoolkit-utils"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm font-medium hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm19.2 19.2H12V7.2H7.2v12H4.8V4.8h14.4v14.4z"/></svg>
          NPM Package
        </a>
        <a
          href="https://github.com/vicnail1274-oss/devtoolkit-utils"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </section>

    <!-- Support This Project -->
    <section class="bg-gradient-to-r from-pink-50 to-purple-50 dark:from-pink-950/30 dark:to-purple-950/30 rounded-xl border border-pink-200 dark:border-pink-800/50 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Support This Project</h2>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-5">
        DevToolkit is free and open source. If these tools save you time, consider supporting us to keep the project going.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="https://ko-fi.com/devtoolkit"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-lg text-sm font-medium hover:bg-red-200 dark:hover:bg-red-900/50 transition-colors"
        >
          Ko-fi
        </a>
        <a
          href="https://buymeacoffee.com/devtoolkit"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 rounded-lg text-sm font-medium hover:bg-yellow-200 dark:hover:bg-yellow-900/50 transition-colors"
        >
          Buy Me a Coffee
        </a>
        <a
          href="https://github.com/sponsors/vicnail1274-oss"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 rounded-lg text-sm font-medium hover:bg-purple-200 dark:hover:bg-purple-900/50 transition-colors"
        >
          GitHub Sponsors
        </a>
        <a
          href="/sponsors"
          class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          Learn more &rarr;
        </a>
      </div>
    </section>

    <!-- Links -->
    <section class="text-center space-y-4">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Links</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">All Tools</a>
        <a href="/changelog" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">Changelog</a>
        <a href="/blog" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">Blog</a>
        <a href="/pricing" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">Pricing</a>
        <a href="/newsletter" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">Newsletter</a>
        <a href="/sponsors" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">Support Us</a>
      </div>
    </section>
  </div>
</ToolLayout>
