---
import ToolCard from './ToolCard.astro';
import { getToolsForBlog } from '../data/tools';

export interface Props {
  blogSlug: string;
}

const { blogSlug } = Astro.props;
const relatedTools = getToolsForBlog(blogSlug, 3);
---

{relatedTools.length > 0 && (
  <div class="mt-10 p-6 bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800">
    <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-1">Try These Tools</h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Related free tools mentioned in this article</p>
    <div class="grid grid-cols-1 gap-3">
      {relatedTools.map((tool) => (
        <ToolCard {...tool} />
      ))}
    </div>
    <div class="text-center mt-4">
      <a href="/tools" class="text-sm font-medium text-primary-600 dark:text-primary-400 hover:underline">
        Browse all tools &rarr;
      </a>
    </div>
  </div>
)}
