    )}

    <!-- Custom Event Tracking -->
    <script is:inline>
      (function() {
        var endpoint = '/api/analytics/track';
        function track(event, slug, label) {
          try {
            navigator.sendBeacon(endpoint, JSON.stringify({ event: event, slug: slug || location.pathname, label: label }));
          } catch(e) {}
        }

        // Track page view
        track('page_view', location.pathname);

        // Track tool usage — listen for any form submit or button click inside .tool-container
        document.addEventListener('click', function(e) {
          var btn = e.target.closest('[data-track-cta]');
          if (btn) {
            track('cta_click', location.pathname, btn.getAttribute('data-track-cta'));
            return;
          }
          // Track tool action buttons (Run, Format, Convert, Generate, etc.)
          var toolBtn = e.target.closest('.tool-container button, .tool-container [role="button"]');
          if (toolBtn && !toolBtn.closest('nav') && !toolBtn.closest('header')) {
            var toolSlug = location.pathname.replace('/tools/', '');
            track('tool_use', toolSlug);
          }
        });
      })();
    </script>

    <!-- Copy Link Script -->
    <script is:inline>
      const copyBtn = document.getElementById('copy-link-btn');
      const copyText = document.getElementById('copy-link-text');
      copyBtn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          if (copyText) copyText.textContent = 'Copied!';
          setTimeout(() => { if (copyText) copyText.textContent = 'Copy Link'; }, 2000);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = window.location.href;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          if (copyText) copyText.textContent = 'Copied!';
          setTimeout(() => { if (copyText) copyText.textContent = 'Copy Link'; }, 2000);
        }
      });
    </script>

    <!-- Dark Mode Toggle Script -->
    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      // Check saved preference or system preference
      if (localStorage.getItem('theme') === 'light' ||
          (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: light)').matches)) {
        html.classList.remove('dark');
      }

      toggle?.addEventListener('click', () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      });
    </script>
